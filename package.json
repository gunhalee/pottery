    "smoke:admin-media": "node scripts/smoke-admin-media.mjs",
    "smoke:fallbacks": "node scripts/smoke-fallbacks.mjs",
    "smoke:routes": "node scripts/smoke-routes.mjs",
    "smoke:supabase": "node scripts/smoke-supabase-rpc.mjs",
    "typecheck": "tsc --noEmit",
    "verify:core": "npm run lint && npm run typecheck && npm run smoke:fallbacks && npm run clean:next && npm run build && npm run perf:assets:budget && npm run smoke:routes && npm run smoke:admin-media && npm run smoke:admin-editors"
  },
  "dependencies": {
    "@lexical/code": "^0.44.0",
